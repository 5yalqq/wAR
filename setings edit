-- ==========================================
-- 2. البرمجة والمنطق
-- ==========================================
local selectedVictim = nil
local isSpoofing = false
local fakeUsername = ""
local fakeDisplayName = ""
local fakeAvatar = ""

local function refreshDropdown()
    for _, child in pairs(DropdownList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, player in pairs(Players:GetPlayers()) do
        local btn = Instance.new("TextButton")
        btn.Size = UDim2.new(1, 0, 0, 35)
        btn.BackgroundColor3 = Color3.fromRGB(55, 55, 55)
        btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        btn.Text = "  " .. player.Name
        btn.Font = Enum.Font.Gotham
        btn.TextXAlignment = Enum.TextXAlignment.Left
        btn.TextSize = 14
        btn.ZIndex = 11
        btn.Parent = DropdownList
        
        btn.MouseButton1Click:Connect(function()
            selectedVictim = player
            DropdownButton.Text = "الهدف: " .. player.Name
            DropdownList.Visible = false
        end)
    end
    DropdownList.CanvasSize = UDim2.new(0, 0, 0, #Players:GetPlayers() * 35)
end

DropdownButton.MouseButton1Click:Connect(function()
    DropdownList.Visible = not DropdownList.Visible
    if DropdownList.Visible then refreshDropdown() end
end)

ApplyButton.MouseButton1Click:Connect(function()
    if not selectedVictim then
        ApplyButton.Text = "⚠️ اختر لاعباً أولاً"
        task.wait(1.5)
        ApplyButton.Text = "تطبيق التغيير الآن"
        return
    end

    local input = TargetInput.Text
    local targetId = tonumber(input)
    
    ApplyButton.Text = "جاري النسخ..."

    if not targetId and input ~= "" then
        local success, result = pcall(function() return Players:GetUserIdFromNameAsync(input) end)
        if success then targetId = result end
    end

    if targetId then
        local success, userInfo = pcall(function() return UserService:GetUserInfosByUserIdsAsync({targetId}) end)
        if success and userInfo[1] then
            fakeUsername = userInfo[1].Username
            fakeDisplayName = userInfo[1].DisplayName
            -- رابط صورة الجسم الكامل
            fakeAvatar = "rbxthumb://type=Avatar&id="..targetId.."&w=420&h=420"
            
            isSpoofing = true
            ApplyButton.Text = "✅ تم بنجاح!"
            ApplyButton.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
            task.wait(2)
            ApplyButton.Text = "تطبيق التغيير الآن"
            ApplyButton.BackgroundColor3 = Color3.fromRGB(0, 130, 220)
        else
            ApplyButton.Text = "❌ فشل جلب البيانات"
            task.wait(1.5)
            ApplyButton.Text = "تطبيق التغيير الآن"
        end
    end
end)

-- إخفاء وإظهار
UserInputService.InputBegan:Connect(function(input, gpe)
    if not gpe and (input.KeyCode == Enum.KeyCode.Zero or input.KeyCode == Enum.KeyCode.KeypadZero) then
        ScreenGui.Enabled = not ScreenGui.Enabled
    end
end)

-- التعديل المباشر على الواجهة الرسمية
RunService.RenderStepped:Connect(function()
    if isSpoofing and selectedVictim then
        local robloxGui = CoreGui:FindFirstChild("RobloxGui")
        if robloxGui then
            for _, v in pairs(robloxGui:GetDescendants()) do
                if v:IsA("TextLabel") then
                    if v.Text == selectedVictim.DisplayName then v.Text = fakeDisplayName
                    elseif v.Text == "@" .. selectedVictim.Name then v.Text = "@" .. fakeUsername
                    elseif v.Text == selectedVictim.Name then v.Text = fakeUsername
                    end
                elseif v:IsA("ImageLabel") then
                    -- استبدال صورة الشخص في الليدربورد والدردشة بصورة الجسم كامل
                    if v.Image:find(tostring(selectedVictim.UserId)) then
                        v.Image = fakeAvatar
                    end
                end
            end
        end
    end
end)
